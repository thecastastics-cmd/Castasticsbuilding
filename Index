<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>World Rebuilder RPG</title>
    <style>
        body { background: #222; color: #fff; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; }
        canvas { background: #333; border: 4px solid #555; margin-top: 10px; cursor: crosshair; }
        .stats { display: flex; gap: 20px; font-size: 1.2rem; margin: 10px; padding: 10px; background: #444; border-radius: 8px; }
        .controls { margin: 10px; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }
        button { padding: 10px; cursor: pointer; background: #e67e22; border: none; color: white; font-weight: bold; border-radius: 4px; }
        button:disabled { background: #777; cursor: not-allowed; }
    </style>
</head>
<body>

    <div class="stats">
        <div>Level: <span id="lvl">1</span></div>
        <div>Money: $<span id="money">500</span></div>
        <div>XP: <span id="xp">0</span> / <span id="xpReq">100</span></div>
    </div>

    <div class="controls" id="shop-ui">
        </div>

    <canvas id="gameCanvas" width="800" height="500"></canvas>

<script>
/** * GAME DATA 
 * Add your 440+ characters and buildings here!
 */
const BUILDINGS_DATA = [
    { id: 1, name: "Starter Hut", cost: 100, lvl: 1, income: 5, img: "building1.png", charImg: "char1.png" },
    { id: 2, name: "Merchant Shop", cost: 300, lvl: 2, income: 20, img: "building2.png", charImg: "char2.png" },
    { id: 3, name: "Warrior Hall", cost: 800, lvl: 5, income: 0, img: "building3.png", charImg: "char3.png" }
];

class Game {
    constructor() {
        this.money = 500;
        this.xp = 0;
        this.level = 1;
        this.buildings = []; // Objects actually placed on map
        this.npcs = [];      // Characters wandering around
        this.canvas = document.getElementById('gameCanvas');
        this.ctx = this.canvas.getContext('2d');
        
        this.init();
    }

    init() {
        this.renderShop();
        this.gameLoop();
        // Collect money every 3 seconds
        setInterval(() => this.collectIncome(), 3000);
    }

    getXpNeeded() {
        return Math.floor(Math.pow(this.level, 1.5) * 100);
    }

    addXp(amt) {
        this.xp += amt;
        if (this.xp >= this.getXpNeeded()) {
            this.xp = 0;
            this.level++;
            this.renderShop(); // Refresh buttons for new unlocks
        }
        this.updateUI();
    }

    updateUI() {
        document.getElementById('money').innerText = this.money;
        document.getElementById('lvl').innerText = this.level;
        document.getElementById('xp').innerText = this.xp;
        document.getElementById('xpReq').innerText = this.getXpNeeded();
    }

    renderShop() {
        const shop = document.getElementById('shop-ui');
        shop.innerHTML = "";
        BUILDINGS_DATA.forEach(b => {
            const btn = document.createElement('button');
            btn.innerText = `Build ${b.name} ($${b.cost})`;
            btn.disabled = (this.money < b.cost || this.level < b.lvl);
            btn.onclick = () => this.buyBuilding(b);
            shop.appendChild(btn);
        });
    }

    buyBuilding(data) {
        if (this.money >= data.cost) {
            this.money -= data.cost;
            
            // Create building instance with random map position
            const newBldg = {
                ...data,
                x: Math.random() * (this.canvas.width - 50),
                y: Math.random() * (this.canvas.height - 50),
                imageObj: new Image()
            };
            newBldg.imageObj.src = data.img; // Points to building1.png etc.
            
            this.buildings.push(newBldg);
            
            // Spawn the associated character
            this.spawnNpc(data.charImg);
            
            this.addXp(50);
            this.renderShop();
        }
    }

    spawnNpc(imgSrc) {
        const npc = {
            x: Math.random() * this.canvas.width,
            y: Math.random() * this.canvas.height,
            targetX: Math.random() * this.canvas.width,
            targetY: Math.random() * this.canvas.height,
            imageObj: new Image(),
            speed: 0.5 + Math.random()
        };
        npc.imageObj.src = imgSrc; // Points to char1.png etc.
        this.npcs.push(npc);
    }

    collectIncome() {
        this.buildings.forEach(b => this.money += b.income);
        this.updateUI();
        this.renderShop();
    }

    updateNpcs() {
        this.npcs.forEach(npc => {
            // Simple wander logic: move toward target
            let dx = npc.targetX - npc.x;
            let dy = npc.targetY - npc.y;
            let dist = Math.sqrt(dx*dx + dy*dy);

            if (dist > 5) {
                npc.x += (dx / dist) * npc.speed;
                npc.y += (dy / dist) * npc.speed;
            } else {
                // Pick new random spot to walk to
                npc.targetX = Math.random() * this.canvas.width;
                npc.targetY = Math.random() * this.canvas.height;
            }
        });
    }

    draw() {
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

        // Draw Buildings
        this.buildings.forEach(b => {
            // If image fails to load, draw a colored box as fallback
            if (b.imageObj.complete) {
                this.ctx.drawImage(b.imageObj, b.x, b.y, 60, 60);
            } else {
                this.ctx.fillStyle = "brown";
                this.ctx.fillRect(b.x, b.y, 60, 60);
            }
        });

        // Draw NPCs
        this.npcs.forEach(n => {
            if (n.imageObj.complete) {
                this.ctx.drawImage(n.imageObj, n.x, n.y, 30, 30);
            } else {
                this.ctx.fillStyle = "cyan";
                this.ctx.beginPath();
                this.ctx.arc(n.x, n.y, 10, 0, Math.PI*2);
                this.ctx.fill();
            }
        });
    }

    gameLoop() {
        this.updateNpcs();
        this.draw();
        requestAnimationFrame(() => this.gameLoop());
    }
}

// Start the game
const worldGame = new Game();
</script>
</body>
</html>
